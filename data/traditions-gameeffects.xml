	<Modifier id="MOD_JEC_RITUAL_PITS_CULTURE" collection="COLLECTION_PLAYER_CITIES" effect="EFFECT_CITY_GRANT_WAREHOUSE_YIELD">
		<Argument name="WarehouseYieldChange">HittiteRitualPitsClayPitsCulture, HittiteRitualPitsMineCulture, HittiteRitualPitsMineResouceCulture, HittiteRitualPitsQuarryCulture</Argument>
