		<Argument name="Tooltip">LOC_TRADITION_HITTITE_RITUAL_PITS_NAME</Argument>
		<String context="Description">LOC_MOD_JEC_RITUAL_PITS_PRODUCTION_DESCRIPTION</String>
	</Modifier>

